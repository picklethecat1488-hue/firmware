{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug Test (Nextest)",
      "cargo": {
        "args": [
          "nextest",
          "run",
          "--no-run"
        ]
      },
      "args": [],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "cortex-debug",
      "request": "launch",
      "name": "Debug App (Cortex-Debug J-Link)",
      "servertype": "jlink",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/target/thumbv6m-none-eabi/debug/cat_detector_app",
      "device": "RP2040",
      "interface": "swd",
      "runToEntryPoint": "main"
    },
    {
      "type": "cortex-debug",
      "request": "launch",
      "name": "Debug Shell (Cortex-Debug J-Link)",
      "servertype": "jlink",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/target/thumbv6m-none-eabi/debug/cat_detector_shell",
      "device": "RP2040",
      "interface": "swd",
      "runToEntryPoint": "main"
    },
    {
      "type": "cortex-debug",
      "request": "launch",
      "name": "Debug App (Cortex-Debug Pico Probe)",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/target/thumbv6m-none-eabi/debug/cat_detector_app",
      "device": "RP2040",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/rp2040.cfg",
        ".vscode/openocd_custom.cfg"
      ],
      "openOCDLaunchCommands": [
        "adapter speed 5000"
      ],
      "runToEntryPoint": "main",
      "serverPort": 3333
    },
    {
      "type": "cortex-debug",
      "request": "launch",
      "name": "Debug Shell (Cortex-Debug Pico Probe)",
      "servertype": "openocd",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/target/thumbv6m-none-eabi/debug/cat_detector_shell",
      "device": "RP2040",
      "configFiles": [
        "interface/cmsis-dap.cfg",
        "target/rp2040.cfg",
        ".vscode/openocd_custom.cfg"
      ],
      "openOCDLaunchCommands": [
        "adapter speed 5000"
      ],
      "runToEntryPoint": "main",
      "serverPort": 3333
    }
  ]
}